# Zerodha Kite Connect
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=auto_generated_daily

# Database
DATABASE_URL=postgresql://tradeking:password@localhost:5432/tradeking_db
REDIS_URL=redis://localhost:6379

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_personal_chat_id

# Trading Capital (for risk calculations)
TOTAL_CAPITAL=600000
MAX_RISK_PER_TRADE_PCT=15
DAILY_LOSS_LIMIT_PCT=2

# Engine Settings
ENGINE_REFRESH_SECONDS=300
OTM_SPIKE_MULTIPLIER=3.0
BLOCK_TRADE_NIFTY_LOTS=500
IVR_GATE_THRESHOLD=60
TRAP_MIN_CONDITIONS=3

# Expiry Calendar
CURRENT_EXPIRY_DATE=2026-04-03
